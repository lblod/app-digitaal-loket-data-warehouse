DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://mu.semte.ch/vocabularies/ext/VerkiezingsresultaatGevolgCode> ; ?p ?o .
  }
};

# Fractietype
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://mu.semte.ch/vocabularies/ext/Fractietype> ; ?p ?o .
  }
};

# Membership
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://www.w3.org/ns/org#Membership> ; ?p ?o .
  }
};

# --- persons-sensitive-consumer types ---

# Person
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://www.w3.org/ns/person#Person> ; ?p ?o .
  }
};

# Geboorte
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <https://data.vlaanderen.be/ns/persoon#Geboorte> ; ?p ?o .
  }
};

# GeslachtCode
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://mu.semte.ch/vocabularies/ext/GeslachtCode> ; ?p ?o .
