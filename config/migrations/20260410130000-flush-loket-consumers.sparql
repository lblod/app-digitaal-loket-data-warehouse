# Flush data from mandatendatabank, persons-sensitive, and leidinggevenden consumers
# to allow a clean initial re-sync with triple remapping enabled.
#
# Types shared with OP (ContactPoint, Address, Identifier, etc.) are also flushed.
# An OP re-sync should follow to repopulate those.

# --- mandatendatabank-consumer types ---

# Mandataris
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://data.vlaanderen.be/ns/mandaat#Mandataris> ; ?p ?o .
  }
};

# Fractie
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://data.vlaanderen.be/ns/mandaat#Fractie> ; ?p ?o .
  }
};

# BeleidsdomeinCode
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://mu.semte.ch/vocabularies/ext/BeleidsdomeinCode> ; ?p ?o .
  }
};

# KandidatenlijstLijsttype
DELETE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> { ?s ?p ?o }
}
WHERE {
  GRAPH <http://mu.semte.ch/graphs/datawarehouse> {
    ?s a <http://mu.semte.ch/vocabularies/ext/KandidatenlijstLijsttype> ; ?p ?o .
  }
};

