PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX mu:      <http://mu.semte.ch/vocabularies/core/>
PREFIX dct:     <http://purl.org/dc/terms/>
PREFIX schema:  <http://schema.org/>
PREFIX org:     <http://www.w3.org/ns/org#>
PREFIX mandaat: <http://data.vlaanderen.be/ns/mandaat#>
PREFIX ch:      <http://data.lblod.info/vocabularies/contacthub/>
PREFIX ere:     <http://data.lblod.info/vocabularies/erediensten/>

# AgentInPositie is the abstract supertype; subjects also carry their
# concrete subtype (Mandataris / EredienstMandataris / RolBedienaar).
# Loket-only worship date predicates are preserved here because OP has
# no equivalent and the source uses them for RolBedienaar.

CONSTRUCT {
  ?s ?p ?o .
} WHERE {
  ?s a ch:AgentInPositie ;
     ?p ?o .

  FILTER (?p IN (
    rdf:type,
    mu:uuid,
    dct:modified,
    schema:contactPoint,
    org:holds,
    org:heldBy,
    mandaat:isBestuurlijkeAliasVan,
    mandaat:start,
    mandaat:einde,
    mandaat:status,
    ch:startdatum,
    ch:eindedatum,
    ere:geplandeEinddatumAanstelling
  ))
}
